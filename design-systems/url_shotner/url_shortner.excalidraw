      "isDeleted": false,
      "boundElements": null,
      "updated": 1782301633108,
      "link": null,
      "locked": false,
      "text": "Base62 is preferred because it guarantees unique short codes when encoding unique IDs, while truncated MD5 hashes can cause collisions.\nBase62 also provides a much larger usable key space and simpler lookups.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Base62 is preferred because it guarantees unique short codes when encoding unique IDs, while truncated MD5 hashes can cause collisions.\nBase62 also provides a much larger usable key space and simpler lookups.",
      "autoResize": true,
      "lineHeight": 1.25
    },
