    {
      "id": "SPzoofDTswPMGgEHS9Rpi",
      "type": "text",
      "x": 647.8043740422318,
      "y": 1145.6458178903285,
      "width": 1652.9016723632817,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
