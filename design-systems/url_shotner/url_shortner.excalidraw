      "index": "b0Fz",
      "roundness": null,
      "seed": 1499125555,
      "version": 1758,
      "versionNonce": 1318962973,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1782298985049,
      "link": null,
      "locked": false,
      "text": "Due to the birthday paradox, collisions appear much earlier than the total key space suggests. For a 7-character hexadecimal code space (16⁷ ≈ 268M), collisions become\nlikely around √268M ≈ 16K generated URLs, making simple hash truncation unsuitable at scale.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Due to the birthday paradox, collisions appear much earlier than the total key space suggests. For a 7-character hexadecimal code space (16⁷ ≈ 268M), collisions become likely around √268M ≈ 16K generated URLs, making simple hash truncation unsuitable at scale.",
      "autoResize": false,
      "lineHeight": 1.25
    },
